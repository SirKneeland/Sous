# Supabase — from your Supabase project settings (Project Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Secret used to sign Sous session tokens (JWTs). Generate a long random string:
#   openssl rand -base64 48
JWT_SECRET=

# Port the API listens on. Railway sets this automatically in production.
PORT=3000

# Node environment. Use "production" on Railway, "development" locally.
NODE_ENV=development

# --- Apple Sign in with Apple ---
# Your iOS app's bundle identifier (a.k.a. the Apple client_id / audience).
# Leave blank for now; required before real Apple tokens can be validated.
APPLE_CLIENT_ID=

# DEVELOPMENT ONLY: skip Apple identity-token verification so you can test
# /auth/apple in Postman without a real device token. This flag is IGNORED
# (treated as false) whenever NODE_ENV=production, so it can never weaken prod.
BYPASS_APPLE_VERIFY=false

# --- OpenAI proxy (Project 3) ---
# Server-side OpenAI key. Non-BYOK users' chat/TTS calls are forwarded to OpenAI
# using THIS key (never exposed to the client). Required for /proxy/* to work.
OPENAI_API_KEY=

# --- Internal admin dashboard (Project 3) ---
# Separate from user session tokens. Guards GET /api/v1/admin/dashboard. Sent by
# the operator in the X-Admin-Key header. Generate a long random string:
#   openssl rand -base64 32
ADMIN_API_KEY=
